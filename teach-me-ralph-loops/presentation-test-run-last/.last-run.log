{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01FVCUJnjZyKSvpmrAPTLCJs","type":"tool_result","content":"1\t#!/bin/bash\n2\t# Experiment 5: Version Mismatch Detection (Integration)\n3\t#\n4\t# Verifies:\n5\t# 1. Build-time enhance an entity with a genuinely DIFFERENT Hibernate ORM version\n6\t#    (6.6.48.Final-redhat-00001) than EAP ships (6.6.51.Final-redhat-00001)\n7\t# 2. Deploy to EAP with classtransformer=true so the runtime enhancer activates\n8\t# 3. Deployment fails with a clear version mismatch error\n9\t#\n10\t# Difference from Experiment 3:\n11\t#   Exp 3 used ASM to rewrite @EnhancementInfo(version=...) to a fake version.\n12\t#   This experiment uses an ACTUAL different Hibernate ORM version (6.6.48) for\n13\t#   the build-time enhancement step, creating a genuine mismatch -- the real-world\n14\t#   scenario a developer would hit.\n15\t\n16\tset -euo pipefail\n17\t\n18\tSCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"\n19\tBASE_DIR=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"\n20\tSOURCES=\"$BASE_DIR/sources\"\n21\tEAP_DIST=\"$SOURCES/8.2.0.Alpha-CR39/jboss-eap-8.2\"\n22\tMODULES=\"$EAP_DIST/modules/system/layers/base\"\n23\t\n24\tAPP_DIR=\"$SCRIPT_DIR/05-test-app-version-mismatch-integration\"\n25\tWORK_DIR=$(mktemp -d /tmp/exp05-version-mismatch-integration.XXXXXX)\n26\t\n27\t# Runtime jars from EAP modules (version 6.6.51)\n28\tHIBERNATE_CORE_RUNTIME=\"$MODULES/org/hibernate/main/hibernate-core-6.6.51.Final-redhat-00001.jar\"\n29\tJPA_API=\"$MODULES/jakarta/persistence/api/main/jakarta.persistence-api-3.1.0.redhat-00002.jar\"\n30\tBYTE_BUDDY_RUNTIME=\"$MODULES/net/bytebuddy/main/byte-buddy-1.17.8.redhat-00001.jar\"\n31\tJBOSS_LOGGING=\"$MODULES/org/jboss/logging/main/jboss-logging-3.6.3.Final-redhat-00001.jar\"\n32\tTX_API=\"$MODULES/jakarta/transaction/api/main/jakarta.transaction-api-2.0.1.redhat-00004.jar\"\n33\tSERVLET_API=\"$MODULES/jakarta/servlet/api/main/jakarta.servlet-api-6.0.0.redhat-00007.jar\"\n34\tEJB_API=\"$MODULES/jakarta/ejb/api/main/jakarta.ejb-api-4.0.1.redhat-00001.jar\"\n35\tINJECT_API=\"$MODULES/jakarta/inject/api/main/jakarta.inject-api-2.0.1.redhat-00007.jar\"\n36\tANNOTATION_API=\"$MODULES/jakarta/annotation/api/main/jakarta.annotation-api-2.1.1.redhat-00005.jar\"\n37\t\n38\t# Build-time jars -- a DIFFERENT Hibernate version (6.6.48) from .m2 local cache\n39\tHIBERNATE_CORE_BUILD=\"$HOME/.m2/repository/org/hibernate/orm/hibernate-core/6.6.48.Final-redhat-00001/hibernate-core-6.6.48.Final-redhat-00001.jar\"\n40\tBYTE_BUDDY_BUILD=\"$HOME/.m2/repository/net/bytebuddy/byte-buddy/1.17.5/byte-buddy-1.17.5.jar\"\n41\t\n42\tBUILD_VERSION=\"6.6.48.Final-redhat-00001\"\n43\tRUNTIME_VERSION=\"6.6.51.Final-redhat-00001\"\n44\t\n45\tEAP_HOME=\"\"\n46\tEAP_PID=\"\"\n47\t\n48\tcleanup() {\n49\t    if [ -n \"$EAP_PID\" ] && kill -0 \"$EAP_PID\" 2>/dev/null; then\n50\t        echo \"Shutting down EAP...\"\n51\t        \"$EAP_HOME/bin/jboss-cli.sh\" --connect --command=\":shutdown\" 2>/dev/null || true\n52\t        sleep 3\n53\t        kill -0 \"$EAP_PID\" 2>/dev/null && kill \"$EAP_PID\" 2>/dev/null || true\n54\t    fi\n55\t    if [ -n \"$WORK_DIR\" ] && [ -d \"$WORK_DIR\" ]; then\n56\t        rm -rf \"$WORK_DIR\"\n57\t    fi\n58\t}\n59\ttrap cleanup EXIT\n60\t\n61\t# Verify all required jars exist\n62\tfor jar in \"$HIBERNATE_CORE_RUNTIME\" \"$JPA_API\" \"$BYTE_BUDDY_RUNTIME\" \"$JBOSS_LOGGING\" \\\n63\t           \"$TX_API\" \"$SERVLET_API\" \"$EJB_API\" \"$INJECT_API\" \"$ANNOTATION_API\"; do\n64\t    if [ ! -f \"$jar\" ]; then\n65\t        echo \"ERROR: Required EAP jar not found: $jar\"\n66\t        exit 1\n67\t    fi\n68\tdone\n69\t\n70\tif [ ! -f \"$HIBERNATE_CORE_BUILD\" ]; then\n71\t    echo \"ERROR: Build-time Hibernate jar not found: $HIBERNATE_CORE_BUILD\"\n72\t    echo \"Need hibernate-core 6.6.48.Final-redhat-00001 in local .m2 cache\"\n73\t    exit 1\n74\tfi\n75\tif [ ! -f \"$BYTE_BUDDY_BUILD\" ]; then\n76\t    echo \"ERROR: Build-time ByteBuddy jar not found: $BYTE_BUDDY_BUILD\"\n77\t    exit 1\n78\tfi\n79\t\n80\techo \"=== Experiment 5: Version Mismatch Detection (Integration) ===\"\n81\techo \"Build-time Hibernate ORM: $BUILD_VERSION\"\n82\techo \"Runtime Hibernate ORM:    $RUNTIME_VERSION\"\n83\techo \"(genuine version mismatch -- no ASM rewriting)\"\n84\t\n85\t# ---- Step 1: Create the test application ----\n86\techo \"\"\n87\techo \"--- Step 1: Creating test application ---\"\n88\t\n89\tmkdir -p \"$APP_DIR/src/main/java/com/test/entity\"\n90\tmkdir -p \"$APP_DIR/src/main/webapp/WEB-INF\"\n91\tmkdir -p \"$APP_DIR/src/main/resources/META-INF\"\n92\t\n93\tcat > \"$APP_DIR/src/main/java/com/test/entity/Employee.java\" << 'JAVA'\n94\tpackage com.test.entity;\n95\t\n96\timport jakarta.persistence.Basic;\n97\timport jakarta.persistence.Entity;\n98\timport jakarta.persistence.FetchType;\n99\timport jakarta.persistence.Id;\n100\timport jakarta.persistence.Lob;\n101\t\n102\t@Entity\n103\tpublic class Employee {\n104\t    @Id\n105\t    private int id;\n106\t\n107\t    private String name;\n108\t    private String address;\n109\t\n110\t    @Basic(fetch = FetchType.LAZY)\n111\t    @Lob\n112\t    private String biography;\n113\t\n114\t    public int getId() { return id; }\n115\t    public void setId(int id) { this.id = id; }\n116\t    public String getName() { return name; }\n117\t    public void setName(String name) { this.name = name; }\n118\t    public String getAddress() { return address; }\n119\t    public void setAddress(String address) { this.address = address; }\n120\t    public String getBiography() { return biography; }\n121\t    public void setBiography(String biography) { this.biography = biography; }\n122\t}\n123\tJAVA\n124\t\n125\tcat > \"$APP_DIR/src/main/resources/META-INF/persistence.xml\" << 'XML'\n126\t<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n127\t<persistence xmlns=\"https://jakarta.ee/xml/ns/persistence\"\n128\t             xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\"\n129\t             xsi:schemaLocation=\"https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd\"\n130\t             version=\"3.0\">\n131\t    <persistence-unit name=\"testPU\">\n132\t        <jta-data-source>java:jboss/datasources/ExampleDS</jta-data-source>\n133\t        <class>com.test.entity.Employee</class>\n134\t        <properties>\n135\t            <property name=\"hibernate.hbm2ddl.auto\" value=\"create-drop\"/>\n136\t            <!-- Enable runtime class transformer so it detects the version mismatch -->\n137\t            <property name=\"jboss.as.jpa.classtransformer\" value=\"true\"/>\n138\t        </properties>\n139\t    </persistence-unit>\n140\t</persistence>\n141\tXML\n142\t\n143\tcat > \"$APP_DIR/src/main/webapp/WEB-INF/web.xml\" << 'XML'\n144\t<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n145\t<web-app xmlns=\"https://jakarta.ee/xml/ns/jakartaee\"\n146\t         xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\"\n147\t         xsi:schemaLocation=\"https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd\"\n148\t         version=\"6.0\">\n149\t</web-app>\n150\tXML\n151\t\n152\t# ---- Step 2: Compile the application ----\n153\techo \"\"\n154\techo \"--- Step 2: Compiling test application ---\"\n155\t\n156\tBUILD_DIR=\"$WORK_DIR/classes\"\n157\tmkdir -p \"$BUILD_DIR\"\n158\t\n159\tCOMPILE_CP=\"$JPA_API:$SERVLET_API:$TX_API:$ANNOTATION_API:$INJECT_API:$EJB_API\"\n160\t\n161\tjavac -d \"$BUILD_DIR\" \\\n162\t    -classpath \"$COMPILE_CP\" \\\n163\t    -source 17 -target 17 \\\n164\t    \"$APP_DIR/src/main/java/com/test/entity/Employee.java\"\n165\t\n166\techo \"Compilation successful\"\n167\t\n168\t# ---- Step 3: Enhance with DIFFERENT Hibernate version (6.6.48) ----\n169\techo \"\"\n170\techo \"--- Step 3: Running build-time enhancement with Hibernate $BUILD_VERSION ---\"\n171\t\n172\tENHANCER_DIR=\"$WORK_DIR/enhancer\"\n173\tmkdir -p \"$ENHANCER_DIR\"\n174\t\n175\tcat > \"$ENHANCER_DIR/RunEnhancer.java\" << 'JAVA'\n176\timport org.hibernate.bytecode.enhance.spi.DefaultEnhancementContext;\n177\timport org.hibernate.bytecode.enhance.spi.EnhancementContext;\n178\timport org.hibernate.bytecode.enhance.spi.Enhancer;\n179\timport org.hibernate.bytecode.enhance.spi.UnloadedClass;\n180\timport org.hibernate.bytecode.enhance.spi.UnloadedField;\n181\timport org.hibernate.bytecode.enhance.internal.bytebuddy.EnhancerImpl;\n182\timport org.hibernate.bytecode.internal.bytebuddy.ByteBuddyState;\n183\t\n184\timport java.io.*;\n185\timport java.nio.file.*;\n186\timport java.nio.file.attribute.BasicFileAttributes;\n187\t\n188\tpublic class RunEnhancer {\n189\t    public static void main(String[] args) throws Exception {\n190\t        if (args.length < 1) {\n191\t            System.err.println(\"Usage: RunEnhancer <classes-dir>\");\n192\t            System.exit(1);\n193\t        }\n194\t\n195\t        Path classesDir = Paths.get(args[0]);\n196\t\n197\t        EnhancementContext context = new DefaultEnhancementContext() {\n198\t            @Override\n199\t            public boolean doBiDirectionalAssociationManagement(UnloadedField field) {\n200\t                return false;\n201\t            }\n202\t            @Override\n203\t            public boolean doDirtyCheckingInline(UnloadedClass classDescriptor) {\n204\t                return true;\n205\t            }\n206\t            @Override\n207\t            public boolean doExtendedEnhancement(UnloadedClass classDescriptor) {\n208\t                return false;\n209\t            }\n210\t            @Override\n211\t            public boolean hasLazyLoadableAttributes(UnloadedClass classDescriptor) {\n212\t                return true;\n213\t            }\n214\t            @Override\n215\t            public ClassLoader getLoadingClassLoader() {\n216\t                return Thread.currentThread().getContextClassLoader();\n217\t            }\n218\t        };\n219\t\n220\t        Enhancer enhancer = new EnhancerImpl(context, new ByteBuddyState());\n221\t\n222\t        Files.walkFileTree(classesDir, new SimpleFileVisitor<Path>() {\n223\t            @Override\n224\t            public FileVisitResult visitFile(Path file, BasicFileAttributes attrs) throws IOException {\n225\t                if (file.toString().endsWith(\".class\")) {\n226\t                    String relativePath = classesDir.relativize(file).toString();\n227\t                    String className = relativePath\n228\t                        .replace(File.separatorChar, '.')\n229\t                        .replace('/', '.')\n230\t                        .replaceAll(\"\\\\.class$\", \"\");\n231\t\n232\t                    if (className.contains(\".entity.\")) {\n233\t                        System.out.println(\"Enhancing: \" + className);\n234\t                        byte[] original = Files.readAllBytes(file);\n235\t                        byte[] enhanced = enhancer.enhance(className, original);\n236\t                        if (enhanced != null) {\n237\t                            Files.write(file, enhanced);\n238\t                            System.out.println(\"  -> Enhanced successfully (\" +\n239\t                                original.length + \" -> \" + enhanced.length + \" bytes)\");\n240\t                        } else {\n241\t                            System.out.println(\"  -> No enhancement needed\");\n242\t                        }\n243\t                    }\n244\t                }\n245\t                return FileVisitResult.CONTINUE;\n246\t            }\n247\t        });\n248\t    }\n249\t}\n250\tJAVA\n251\t\n252\t# Use the 6.6.48 hibernate-core and matching byte-buddy for enhancement\n253\tENHANCER_CP=\"$HIBERNATE_CORE_BUILD:$JPA_API:$BYTE_BUDDY_BUILD:$JBOSS_LOGGING:$TX_API:$INJECT_API:$BUILD_DIR\"\n254\t\n255\tjavac -d \"$ENHANCER_DIR\" \\\n256\t    -classpath \"$ENHANCER_CP\" \\\n257\t    \"$ENHANCER_DIR/RunEnhancer.java\"\n258\t\n259\tjava -classpath \"$ENHANCER_DIR:$ENHANCER_CP\" RunEnhancer \"$BUILD_DIR\"\n260\t\n261\t# ---- Step 4: Verify @EnhancementInfo has the 6.6.48 version ----\n262\techo \"\"\n263\techo \"--- Step 4: Verifying @EnhancementInfo annotation ---\"\n264\t\n265\tJAVAP_OUTPUT=$(javap -p -v -classpath \"$BUILD_DIR\" com.test.entity.Employee 2>&1)\n266\tif echo \"$JAVAP_OUTPUT\" | grep -q \"EnhancementInfo\"; then\n267\t    echo \"VERIFIED: @EnhancementInfo annotation is present\"\n268\t    echo \"$JAVAP_OUTPUT\" | grep -A2 \"EnhancementInfo\"\n269\t\n270\t    if echo \"$JAVAP_OUTPUT\" | grep -q \"$BUILD_VERSION\"; then\n271\t        echo \"VERIFIED: Enhancement version is $BUILD_VERSION (differs from runtime $RUNTIME_VERSION)\"\n272\t    else\n273\t        echo \"WARNING: Expected version $BUILD_VERSION not found in annotation\"\n274\t    fi\n275\telse\n276\t    echo \"WARNING: @EnhancementInfo annotation NOT found\"\n277\tfi\n278\t\n279\t# ---- Step 5: Package as WAR ----\n280\techo \"\"\n281\techo \"--- Step 5: Packaging WAR ---\"\n282\t\n283\tWAR_DIR=\"$WORK_DIR/war\"\n284\tmkdir -p \"$WAR_DIR/WEB-INF/classes\"\n285\t\n286\tcp -r \"$BUILD_DIR\"/* \"$WAR_DIR/WEB-INF/classes/\"\n287\tcp \"$APP_DIR/src/main/webapp/WEB-INF/web.xml\" \"$WAR_DIR/WEB-INF/\"\n288\tmkdir -p \"$WAR_DIR/WEB-INF/classes/META-INF\"\n289\tcp \"$APP_DIR/src/main/resources/META-INF/persistence.xml\" \"$WAR_DIR/WEB-INF/classes/META-INF/\"\n290\t\n291\tWAR_FILE=\"$WORK_DIR/test-mismatch-integration.war\"\n292\t(cd \"$WAR_DIR\" && jar cf \"$WAR_FILE\" .)\n293\techo \"WAR created: $WAR_FILE\"\n294\t\n295\t# ---- Step 6: Start EAP ----\n296\techo \"\"\n297\techo \"--- Step 6: Starting EAP 8.2 ---\"\n298\t\n299\tEAP_HOME=\"$WORK_DIR/eap\"\n300\tcp -r \"$EAP_DIST\" \"$EAP_HOME\"\n301\t\n302\tcat > \"$WORK_DIR/enable-trace.cli\" << 'CLI'\n303\tembed-server\n304\t/subsystem=logging/logger=org.hibernate.bytecode.enhance:add(level=TRACE)\n305\t/subsystem=logging/logger=org.jboss.as.jpa:add(level=TRACE)\n306\t/subsystem=logging/logger=org.hibernate.engine.internal:add(level=DEBUG)\n307\tstop-embedded-server\n308\tCLI\n309\t\n310\t\"$EAP_HOME/bin/jboss-cli.sh\" --file=\"$WORK_DIR/enable-trace.cli\" 2>&1 | tail -5\n311\t\n312\t\"$EAP_HOME/bin/standalone.sh\" -b 0.0.0.0 > \"$WORK_DIR/eap-stdout.log\" 2>&1 &\n313\tEAP_PID=$!\n314\techo \"EAP started with PID: $EAP_PID\"\n315\t\n316\techo \"Waiting for EAP to start...\"\n317\tREADY=false\n318\tfor i in $(seq 1 60); do\n319\t    if \"$EAP_HOME/bin/jboss-cli.sh\" --connect --command=\":read-attribute(name=server-state)\" 2>/dev/null | grep -q \"running\"; then\n320\t        READY=true\n321\t        break\n322\t    fi\n323\t    sleep 2\n324\tdone\n325\t\n326\tif [ \"$READY\" != \"true\" ]; then\n327\t    echo \"ERROR: EAP failed to start within 120 seconds\"\n328\t    cat \"$WORK_DIR/eap-stdout.log\" | tail -30\n329\t    exit 1\n330\tfi\n331\techo \"EAP is running\"\n332\t\n333\t# ---- Step 7: Deploy the application ----\n334\techo \"\"\n335\techo \"--- Step 7: Deploying test application (expecting failure) ---\"\n336\t\n337\tcp \"$WAR_FILE\" \"$EAP_HOME/standalone/deployments/\"\n338\ttouch \"$EAP_HOME/standalone/deployments/test-mismatch-integration.war.dodeploy\"\n339\t\n340\techo \"Waiting for deployment result...\"\n341\tDEPLOYED=false\n342\tDEPLOY_FAILED=false\n343\tfor i in $(seq 1 30); do\n344\t    if [ -f \"$EAP_HOME/standalone/deployments/test-mismatch-integration.war.deployed\" ]; then\n345\t        DEPLOYED=true\n346\t        break\n347\t    fi\n348\t    if [ -f \"$EAP_HOME/standalone/deployments/test-mismatch-integration.war.failed\" ]; then\n349\t        DEPLOY_FAILED=true\n350\t        break\n351\t    fi\n352\t    sleep 2\n353\tdone\n354\t\n355\tSERVER_LOG=\"$EAP_HOME/standalone/log/server.log\"\n356\t\n357\t# ---- Step 8: Check for version mismatch error ----\n358\techo \"\"\n359\techo \"--- Step 8: Checking for version mismatch error ---\"\n360\t\n361\tMISMATCH_FOUND=false\n362\tMISMATCH_MSG=\"\"\n363\tif grep -q \"Mismatch between Hibernate version\" \"$SERVER_LOG\"; then\n364\t    MISMATCH_FOUND=true\n365\t    MISMATCH_MSG=$(grep \"Mismatch between Hibernate version\" \"$SERVER_LOG\" | head -3)\n366\t    echo \"FOUND version mismatch error in server log:\"\n367\t    echo \"$MISMATCH_MSG\"\n368\tfi\n369\t\n370\tVERSION_MISMATCH_EXCEPTION=false\n371\tif grep -q \"VersionMismatchException\" \"$SERVER_LOG\"; then\n372\t    VERSION_MISMATCH_EXCEPTION=true\n373\t    echo \"\"\n374\t    echo \"FOUND VersionMismatchException in server log:\"\n375\t    grep \"VersionMismatchException\" \"$SERVER_LOG\" | head -3\n376\tfi\n377\t\n378\techo \"\"\n379\techo \"Enhancement-related log messages:\"\n380\tgrep -i \"enhance\\|bytecode\\|classtransformer\\|EnhancementInfo\" \"$SERVER_LOG\" | head -30 || echo \"(none found)\"\n381\t\n382\techo \"\"\n383\techo \"Deployment error messages:\"\n384\tgrep -i \"ERROR\\|WFLYCTL\\|failed\\|exception\" \"$SERVER_LOG\" | tail -20 || echo \"(none found)\"\n385\t\n386\t# ---- Step 9: Evaluate results ----\n387\techo \"\"\n388\techo \"==========================================\"\n389\techo \"=== RESULTS ===\"\n390\techo \"==========================================\"\n391\t\n392\tRESULT=\"PASS\"\n393\t\n394\tif [ \"$DEPLOY_FAILED\" = \"true\" ]; then\n395\t    echo \"OK: Deployment failed as expected\"\n396\telse\n397\t    if [ \"$DEPLOYED\" = \"true\" ]; then\n398\t        echo \"FAIL: Deployment succeeded -- expected it to fail with version mismatch\"\n399\t        RESULT=\"FAIL\"\n400\t    else\n401\t        echo \"INFO: Deployment neither succeeded nor explicitly failed within timeout\"\n402\t        if grep -q \"WFLYSRV0022\\|deploy.*failed\\|deployment.*failed\" \"$SERVER_LOG\"; then\n403\t            echo \"OK: Server log shows deployment failure\"\n404\t        else\n405\t            echo \"FAIL: No deployment failure detected\"\n406\t            RESULT=\"FAIL\"\n407\t        fi\n408\t    fi\n409\tfi\n410\t\n411\tif [ \"$MISMATCH_FOUND\" = \"true\" ]; then\n412\t    echo \"OK: Version mismatch error message found in server log\"\n413\telif [ \"$VERSION_MISMATCH_EXCEPTION\" = \"true\" ]; then\n414\t    echo \"OK: VersionMismatchException found in server log\"\n415\telse\n416\t    echo \"FAIL: No version mismatch error found in server log\"\n417\t    RESULT=\"FAIL\"\n418\tfi\n419\t\n420\techo \"\"\n421\techo \"Expected: deployment fails with 'Mismatch between Hibernate version used for\"\n422\techo \"          bytecode enhancement ($BUILD_VERSION) and runtime ($RUNTIME_VERSION)'\"\n423\techo \"Actual deployment failed: $DEPLOY_FAILED\"\n424\techo \"Actual deployed successfully: $DEPLOYED\"\n425\techo \"Mismatch error in log: $MISMATCH_FOUND\"\n426\techo \"VersionMismatchException in log: $VERSION_MISMATCH_EXCEPTION\"\n427\t\n428\techo \"\"\n429\techo \"==========================================\"\n430\techo \"$RESULT\"\n431\techo \"==========================================\"\n432\t\n433\texit 0\n434\t"}]},"parent_tool_use_id":null,"session_id":"aa443835-14f9-43a2-a882-6515be006913","uuid":"5bf1cdda-e4ec-4a57-9163-4b77117cebfc","timestamp":"2026-06-19T10:42:46.580Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vsalbaba/Workspace/experiment/teach-me-ralph-loops/presentation-test-run-last/output/05-version-mismatch-integration.sh","content":"#!/bin/bash\n# Experiment 5: Version Mismatch Detection (Integration)\n#\n# Verifies:\n# 1. Build-time enhance an entity with a genuinely DIFFERENT Hibernate ORM version\n#    (6.6.48.Final-redhat-00001) than EAP ships (6.6.51.Final-redhat-00001)\n# 2. Deploy to EAP with classtransformer=true so the runtime enhancer activates\n# 3. Deployment fails with a clear version mismatch error\n#\n# Difference from Experiment 3:\n#   Exp 3 used ASM to rewrite @EnhancementInfo(version=...) to a fake version.\n#   This experiment uses an ACTUAL different Hibernate ORM version (6.6.48) for\n#   the build-time enhancement step, creating a genuine mismatch -- the real-world\n#   scenario a developer would hit.\n\nset -euo pipefail\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"\nBASE_DIR=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"\nSOURCES=\"$BASE_DIR/sources\"\nEAP_DIST=\"$SOURCES/8.2.0.Alpha-CR39/jboss-eap-8.2\"\nMODULES=\"$EAP_DIST/modules/system/layers/base\"\n\nAPP_DIR=\"$SCRIPT_DIR/05-test-app-version-mismatch-integration\"\nWORK_DIR=$(mktemp -d /tmp/exp05-version-mismatch-integration.XXXXXX)\n\n# Runtime jars from EAP modules (version 6.6.51)\nHIBERNATE_CORE_RUNTIME=\"$MODULES/org/hibernate/main/hibernate-core-6.6.51.Final-redhat-00001.jar\"\nJPA_API=\"$MODULES/jakarta/persistence/api/main/jakarta.persistence-api-3.1.0.redhat-00002.jar\"\nBYTE_BUDDY_RUNTIME=\"$MODULES/net/bytebuddy/main/byte-buddy-1.17.8.redhat-00001.jar\"\nJBOSS_LOGGING=\"$MODULES/org/jboss/logging/main/jboss-logging-3.6.3.Final-redhat-00001.jar\"\nTX_API=\"$MODULES/jakarta/transaction/api/main/jakarta.transaction-api-2.0.1.redhat-00004.jar\"\nSERVLET_API=\"$MODULES/jakarta/servlet/api/main/jakarta.servlet-api-6.0.0.redhat-00007.jar\"\nEJB_API=\"$MODULES/jakarta/ejb/api/main/jakarta.ejb-api-4.0.1.redhat-00001.jar\"\nINJECT_API=\"$MODULES/jakarta/inject/api/main/jakarta.inject-api-2.0.1.redhat-00007.jar\"\nANNOTATION_API=\"$MODULES/jakarta/annotation/api/main/jakarta.annotation-api-2.1.1.redhat-00005.jar\"\n\n# Build-time jars -- a DIFFERENT Hibernate version (6.6.48) from .m2 local cache\nHIBERNATE_CORE_BUILD=\"$HOME/.m2/repository/org/hibernate/orm/hibernate-core/6.6.48.Final-redhat-00001/hibernate-core-6.6.48.Final-redhat-00001.jar\"\nBYTE_BUDDY_BUILD=\"$HOME/.m2/repository/net/bytebuddy/byte-buddy/1.17.5/byte-buddy-1.17.5.jar\"\n\nBUILD_VERSION=\"6.6.48.Final-redhat-00001\"\nRUNTIME_VERSION=\"6.6.51.Final-redhat-00001\"\n\nEAP_HOME=\"\"\nEAP_PID=\"\"\n\ncleanup() {\n    if [ -n \"$EAP_PID\" ] && kill -0 \"$EAP_PID\" 2>/dev/null; then\n        echo \"Shutting down EAP...\"\n        \"$EAP_HOME/bin/jboss-cli.sh\" --connect --command=\":shutdown\" 2>/dev/null || true\n        sleep 3\n        kill -0 \"$EAP_PID\" 2>/dev/null && kill \"$EAP_PID\" 2>/dev/null || true\n    fi\n    if [ -n \"$WORK_DIR\" ] && [ -d \"$WORK_DIR\" ]; then\n        rm -rf \"$WORK_DIR\"\n    fi\n}\ntrap cleanup EXIT\n\n# Verify all required jars exist\nfor jar in \"$HIBERNATE_CORE_RUNTIME\" \"$JPA_API\" \"$BYTE_BUDDY_RUNTIME\" \"$JBOSS_LOGGING\" \\\n           \"$TX_API\" \"$SERVLET_API\" \"$EJB_API\" \"$INJECT_API\" \"$ANNOTATION_API\"; do\n    if [ ! -f \"$jar\" ]; then\n        echo \"ERROR: Required EAP jar not found: $jar\"\n        exit 1\n    fi\ndone\n\nif [ ! -f \"$HIBERNATE_CORE_BUILD\" ]; then\n    echo \"ERROR: Build-time Hibernate jar not found: $HIBERNATE_CORE_BUILD\"\n    echo \"Need hibernate-core 6.6.48.Final-redhat-00001 in local .m2 cache\"\n    exit 1\nfi\nif [ ! -f \"$BYTE_BUDDY_BUILD\" ]; then\n    echo \"ERROR: Build-time ByteBuddy jar not found: $BYTE_BUDDY_BUILD\"\n    exit 1\nfi\n\necho \"=== Experiment 5: Version Mismatch Detection (Integration) ===\"\necho \"Build-time Hibernate ORM: $BUILD_VERSION\"\necho \"Runtime Hibernate ORM:    $RUNTIME_VERSION\"\necho \"(genuine version mismatch -- no ASM rewriting)\"\n\n# ---- Step 1: Create the test application ----\necho \"\"\necho \"--- Step 1: Creating test application ---\"\n\nmkdir -p \"$APP_DIR/src/main/java/com/test/entity\"\nmkdir -p \"$APP_DIR/src/main/webapp/WEB-INF\"\nmkdir -p \"$APP_DIR/src/main/resources/META-INF\"\n\ncat > \"$APP_DIR/src/main/java/com/test/entity/Employee.java\" << 'JAVA'\npackage com.test.entity;\n\nimport jakarta.persistence.Basic;\nimport jakarta.persistence.Entity;\nimport jakarta.persistence.FetchType;\nimport jakarta.persistence.Id;\nimport jakarta.persistence.Lob;\n\n@Entity\npublic class Employee {\n    @Id\n    private int id;\n\n    private String name;\n    private String address;\n\n    @Basic(fetch = FetchType.LAZY)\n    @Lob\n    private String biography;\n\n    public int getId() { return id; }\n    public void setId(int id) { this.id = id; }\n    public String getName() { return name; }\n    public void setName(String name) { this.name = name; }\n    public String getAddress() { return address; }\n    public void setAddress(String address) { this.address = address; }\n    public String getBiography() { return biography; }\n    public void setBiography(String biography) { this.biography = biography; }\n}\nJAVA\n\ncat > \"$APP_DIR/src/main/resources/META-INF/persistence.xml\" << 'XML'\n<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<persistence xmlns=\"https://jakarta.ee/xml/ns/persistence\"\n             xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\"\n             xsi:schemaLocation=\"https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd\"\n             version=\"3.0\">\n    <persistence-unit name=\"testPU\">\n        <jta-data-source>java:jboss/datasources/ExampleDS</jta-data-source>\n        <class>com.test.entity.Employee</class>\n        <properties>\n            <property name=\"hibernate.hbm2ddl.auto\" value=\"create-drop\"/>\n            <!-- Enable runtime class transformer so it detects the version mismatch -->\n            <property name=\"jboss.as.jpa.classtransformer\" value=\"true\"/>\n        </properties>\n    </persistence-unit>\n</persistence>\nXML\n\ncat > \"$APP_DIR/src/main/webapp/WEB-INF/web.xml\" << 'XML'\n<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<web-app xmlns=\"https://jakarta.ee/xml/ns/jakartaee\"\n         xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\"\n         xsi:schemaLocation=\"https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd\"\n         version=\"6.0\">\n</web-app>\nXML\n\n# ---- Step 2: Compile the application ----\necho \"\"\necho \"--- Step 2: Compiling test application ---\"\n\nBUILD_DIR=\"$WORK_DIR/classes\"\nmkdir -p \"$BUILD_DIR\"\n\nCOMPILE_CP=\"$JPA_API:$SERVLET_API:$TX_API:$ANNOTATION_API:$INJECT_API:$EJB_API\"\n\njavac -d \"$BUILD_DIR\" \\\n    -classpath \"$COMPILE_CP\" \\\n    -source 17 -target 17 \\\n    \"$APP_DIR/src/main/java/com/test/entity/Employee.java\"\n\necho \"Compilation successful\"\n\n# ---- Step 3: Enhance with DIFFERENT Hibernate version (6.6.48) ----\necho \"\"\necho \"--- Step 3: Running build-time enhancement with Hibernate $BUILD_VERSION ---\"\n\nENHANCER_DIR=\"$WORK_DIR/enhancer\"\nmkdir -p \"$ENHANCER_DIR\"\n\ncat > \"$ENHANCER_DIR/RunEnhancer.java\" << 'JAVA'\nimport org.hibernate.bytecode.enhance.spi.DefaultEnhancementContext;\nimport org.hibernate.bytecode.enhance.spi.EnhancementContext;\nimport org.hibernate.bytecode.enhance.spi.Enhancer;\nimport org.hibernate.bytecode.enhance.spi.UnloadedClass;\nimport org.hibernate.bytecode.enhance.spi.UnloadedField;\nimport org.hibernate.bytecode.enhance.internal.bytebuddy.EnhancerImpl;\nimport org.hibernate.bytecode.internal.bytebuddy.ByteBuddyState;\n\nimport java.io.*;\nimport java.nio.file.*;\nimport java.nio.file.attribute.BasicFileAttributes;\n\npublic class RunEnhancer {\n    public static void main(String[] args) throws Exception {\n        if (args.length < 1) {\n            System.err.println(\"Usage: RunEnhancer <classes-dir>\");\n            System.exit(1);\n        }\n\n        Path classesDir = Paths.get(args[0]);\n\n        EnhancementContext context = new DefaultEnhancementContext() {\n            @Override\n            public boolean doBiDirectionalAssociationManagement(UnloadedField field) {\n                return false;\n            }\n            @Override\n            public boolean doDirtyCheckingInline(UnloadedClass classDescriptor) {\n                return true;\n            }\n            @Override\n            public boolean doExtendedEnhancement(UnloadedClass classDescriptor) {\n                return false;\n            }\n            @Override\n            public boolean hasLazyLoadableAttributes(UnloadedClass classDescriptor) {\n                return true;\n            }\n            @Override\n            public ClassLoader getLoadingClassLoader() {\n                return Thread.currentThread().getContextClassLoader();\n            }\n        };\n\n        Enhancer enhancer = new EnhancerImpl(context, new ByteBuddyState());\n\n        Files.walkFileTree(classesDir, new SimpleFileVisitor<Path>() {\n            @Override\n            public FileVisitResult visitFile(Path file, BasicFileAttributes attrs) throws IOException {\n                if (file.toString().endsWith(\".class\")) {\n                    String relativePath = classesDir.relativize(file).toString();\n                    String className = relativePath\n                        .replace(File.separatorChar, '.')\n                        .replace('/', '.')\n                        .replaceAll(\"\\\\.class$\", \"\");\n\n                    if (className.contains(\".entity.\")) {\n                        System.out.println(\"Enhancing: \" + className);\n                        byte[] original = Files.readAllBytes(file);\n                        byte[] enhanced = enhancer.enhance(className, original);\n                        if (enhanced != null) {\n                            Files.write(file, enhanced);\n                            System.out.println(\"  -> Enhanced successfully (\" +\n                                original.length + \" -> \" + enhanced.length + \" bytes)\");\n                        } else {\n                            System.out.println(\"  -> No enhancement needed\");\n                        }\n                    }\n                }\n                return FileVisitResult.CONTINUE;\n            }\n        });\n    }\n}\nJAVA\n\n# Use the 6.6.48 hibernate-core and matching byte-buddy for enhancement\nENHANCER_CP=\"$HIBERNATE_CORE_BUILD:$JPA_API:$BYTE_BUDDY_BUILD:$JBOSS_LOGGING:$TX_API:$INJECT_API:$BUILD_DIR\"\n\njavac -d \"$ENHANCER_DIR\" \\\n    -classpath \"$ENHANCER_CP\" \\\n    \"$ENHANCER_DIR/RunEnhancer.java\"\n\njava -classpath \"$ENHANCER_DIR:$ENHANCER_CP\" RunEnhancer \"$BUILD_DIR\"\n\n# ---- Step 4: Verify @EnhancementInfo has the 6.6.48 version ----\necho \"\"\necho \"--- Step 4: Verifying @EnhancementInfo annotation ---\"\n\nJAVAP_OUTPUT=$(javap -p -v -classpath \"$BUILD_DIR\" com.test.entity.Employee 2>&1)\nif echo \"$JAVAP_OUTPUT\" | grep -q \"EnhancementInfo\"; then\n    echo \"VERIFIED: @EnhancementInfo annotation is present\"\n    echo \"$JAVAP_OUTPUT\" | grep -A2 \"EnhancementInfo\"\n\n    if echo \"$JAVAP_OUTPUT\" | grep -q \"$BUILD_VERSION\"; then\n        echo \"VERIFIED: Enhancement version is $BUILD_VERSION (differs from runtime $RUNTIME_VERSION)\"\n    else\n        echo \"WARNING: Expected version $BUILD_VERSION not found in annotation\"\n    fi\nelse\n    echo \"WARNING: @EnhancementInfo annotation NOT found\"\nfi\n\n# ---- Step 5: Package as WAR ----\necho \"\"\necho \"--- Step 5: Packaging WAR ---\"\n\nWAR_DIR=\"$WORK_DIR/war\"\nmkdir -p \"$WAR_DIR/WEB-INF/classes\"\n\ncp -r \"$BUILD_DIR\"/* \"$WAR_DIR/WEB-INF/classes/\"\ncp \"$APP_DIR/src/main/webapp/WEB-INF/web.xml\" \"$WAR_DIR/WEB-INF/\"\nmkdir -p \"$WAR_DIR/WEB-INF/classes/META-INF\"\ncp \"$APP_DIR/src/main/resources/META-INF/persistence.xml\" \"$WAR_DIR/WEB-INF/classes/META-INF/\"\n\nWAR_FILE=\"$WORK_DIR/test-mismatch-integration.war\"\n(cd \"$WAR_DIR\" && jar cf \"$WAR_FILE\" .)\necho \"WAR created: $WAR_FILE\"\n\n# ---- Step 6: Start EAP ----\necho \"\"\necho \"--- Step 6: Starting EAP 8.2 ---\"\n\nEAP_HOME=\"$WORK_DIR/eap\"\ncp -r \"$EAP_DIST\" \"$EAP_HOME\"\n\ncat > \"$WORK_DIR/enable-trace.cli\" << 'CLI'\nembed-server\n/subsystem=logging/logger=org.hibernate.bytecode.enhance:add(level=TRACE)\n/subsystem=logging/logger=org.jboss.as.jpa:add(level=TRACE)\n/subsystem=logging/logger=org.hibernate.engine.internal:add(level=DEBUG)\nstop-embedded-server\nCLI\n\n\"$EAP_HOME/bin/jboss-cli.sh\" --file=\"$WORK_DIR/enable-trace.cli\" 2>&1 | tail -5\n\n\"$EAP_HOME/bin/standalone.sh\" -b 0.0.0.0 > \"$WORK_DIR/eap-stdout.log\" 2>&1 &\nEAP_PID=$!\necho \"EAP started with PID: $EAP_PID\"\n\necho \"Waiting for EAP to start...\"\nREADY=false\nfor i in $(seq 1 60); do\n    if \"$EAP_HOME/bin/jboss-cli.sh\" --connect --command=\":read-attribute(name=server-state)\" 2>/dev/null | grep -q \"running\"; then\n        READY=true\n        break\n    fi\n    sleep 2\ndone\n\nif [ \"$READY\" != \"true\" ]; then\n    echo \"ERROR: EAP failed to start within 120 seconds\"\n    cat \"$WORK_DIR/eap-stdout.log\" | tail -30\n    exit 1\nfi\necho \"EAP is running\"\n\n# ---- Step 7: Deploy the application ----\necho \"\"\necho \"--- Step 7: Deploying test application (expecting failure) ---\"\n\ncp \"$WAR_FILE\" \"$EAP_HOME/standalone/deployments/\"\ntouch \"$EAP_HOME/standalone/deployments/test-mismatch-integration.war.dodeploy\"\n\necho \"Waiting for deployment result...\"\nDEPLOYED=false\nDEPLOY_FAILED=false\nfor i in $(seq 1 30); do\n    if [ -f \"$EAP_HOME/standalone/deployments/test-mismatch-integration.war.deployed\" ]; then\n        DEPLOYED=true\n        break\n    fi\n    if [ -f \"$EAP_HOME/standalone/deployments/test-mismatch-integration.war.failed\" ]; then\n        DEPLOY_FAILED=true\n        break\n    fi\n    sleep 2\ndone\n\nSERVER_LOG=\"$EAP_HOME/standalone/log/server.log\"\n\n# ---- Step 8: Check for version mismatch error ----\necho \"\"\necho \"--- Step 8: Checking for version mismatch error ---\"\n\nMISMATCH_FOUND=false\nMISMATCH_MSG=\"\"\nif grep -q \"Mismatch between Hibernate version\" \"$SERVER_LOG\"; then\n    MISMATCH_FOUND=true\n    MISMATCH_MSG=$(grep \"Mismatch between Hibernate version\" \"$SERVER_LOG\" | head -3)\n    echo \"FOUND version mismatch error in server log:\"\n    echo \"$MISMATCH_MSG\"\nfi\n\nVERSION_MISMATCH_EXCEPTION=false\nif grep -q \"VersionMismatchException\" \"$SERVER_LOG\"; then\n    VERSION_MISMATCH_EXCEPTION=true\n    echo \"\"\n    echo \"FOUND VersionMismatchException in server log:\"\n    grep \"VersionMismatchException\" \"$SERVER_LOG\" | head -3\nfi\n\necho \"\"\necho \"Enhancement-related log messages:\"\ngrep -i \"enhance\\|bytecode\\|classtransformer\\|EnhancementInfo\" \"$SERVER_LOG\" | head -30 || echo \"(none found)\"\n\necho \"\"\necho \"Deployment error messages:\"\ngrep -i \"ERROR\\|WFLYCTL\\|failed\\|exception\" \"$SERVER_LOG\" | tail -20 || echo \"(none found)\"\n\n# ---- Step 9: Evaluate results ----\necho \"\"\necho \"==========================================\"\necho \"=== RESULTS ===\"\necho \"==========================================\"\n\nRESULT=\"PASS\"\n\nif [ \"$DEPLOY_FAILED\" = \"true\" ]; then\n    echo \"OK: Deployment failed as expected\"\nelse\n    if [ \"$DEPLOYED\" = \"true\" ]; then\n        echo \"FAIL: Deployment succeeded -- expected it to fail with version mismatch\"\n        RESULT=\"FAIL\"\n    else\n        echo \"INFO: Deployment neither succeeded nor explicitly failed within timeout\"\n        if grep -q \"WFLYSRV0022\\|deploy.*failed\\|deployment.*failed\" \"$SERVER_LOG\"; then\n            echo \"OK: Server log shows deployment failure\"\n        else\n            echo \"FAIL: No deployment failure detected\"\n            RESULT=\"FAIL\"\n        fi\n    fi\nfi\n\nif [ \"$MISMATCH_FOUND\" = \"true\" ]; then\n    echo \"OK: Version mismatch error message found in server log\"\nelif [ \"$VERSION_MISMATCH_EXCEPTION\" = \"true\" ]; then\n    echo \"OK: VersionMismatchException found in server log\"\nelse\n    echo \"FAIL: No version mismatch error found in server log\"\n    RESULT=\"FAIL\"\nfi\n\necho \"\"\necho \"Expected: deployment fails with 'Mismatch between Hibernate version used for\"\necho \"          bytecode enhancement ($BUILD_VERSION) and runtime ($RUNTIME_VERSION)'\"\necho \"Actual deployment failed: $DEPLOY_FAILED\"\necho \"Actual deployed successfully: $DEPLOYED\"\necho \"Mismatch error in log: $MISMATCH_FOUND\"\necho \"VersionMismatchException in log: $VERSION_MISMATCH_EXCEPTION\"\n\necho \"\"\necho \"==========================================\"\necho \"$RESULT\"\necho \"==========================================\"\n\nexit 0\n","numLines":434,"startLine":1,"totalLines":434}}}
