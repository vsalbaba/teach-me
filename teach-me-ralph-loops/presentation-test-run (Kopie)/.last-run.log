{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01U6BordeDUdT1xupMDhSkDY","type":"tool_result","content":"1\t#!/bin/bash\n2\t# Experiment 1: Happy Path -- Build-time Hibernate Entity Enhancement\n3\t#\n4\t# Verifies:\n5\t# 1. hibernate-enhance-maven-plugin produces enhanced bytecode at build time\n6\t# 2. Enhanced app deploys successfully to EAP 8.2\n7\t# 3. Lazy @Basic field loading works (separate SQL for lazy field)\n8\t# 4. Whether HHH90009001 log message appears (not expected in ORM 6.6.x)\n9\t\n10\tset -uo pipefail\n11\t\n12\tSCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"\n13\tBASE_DIR=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"\n14\tSOURCES=\"$BASE_DIR/sources\"\n15\tEAP_HOME_REAL=\"$SOURCES/8.2.0.Alpha-CR39/jboss-eap-8.2\"\n16\tMAVEN_REPO=\"$SOURCES/8.2.0.Alpha-CR39/jboss-eap-8.2.0.Alpha-maven-repository/maven-repository\"\n17\tAPP_DIR=\"$SCRIPT_DIR/01-test-app-happy-path\"\n18\tRESULT=\"ERROR\"\n19\tEAP_PID=\"\"\n20\t\n21\t# EAP's standalone.sh uses eval which breaks on paths with parentheses/spaces.\n22\t# Create symlinks under /tmp to work around this.\n23\tEAP_HOME=\"/tmp/eap-test-01-home\"\n24\tEAP_BASE=\"/tmp/eap-test-01-base\"\n25\t\n26\tcleanup() {\n27\t    if [[ -n \"$EAP_PID\" ]]; then\n28\t        \"$EAP_HOME/bin/jboss-cli.sh\" --connect \\\n29\t            --controller=localhost:19990 command=shutdown 2>/dev/null || true\n30\t        sleep 2\n31\t        kill \"$EAP_PID\" 2>/dev/null || true\n32\t        wait \"$EAP_PID\" 2>/dev/null || true\n33\t    fi\n34\t    rm -f \"$EAP_HOME\" /tmp/enhancement-test.war\n35\t    rm -rf \"$EAP_BASE\"\n36\t    echo \"\"\n37\t    echo \"========================================\"\n38\t    echo \"RESULT: $RESULT\"\n39\t    echo \"========================================\"\n40\t}\n41\ttrap cleanup EXIT\n42\t\n43\t# Set up symlink for JBOSS_HOME (avoids parentheses in path)\n44\trm -f \"$EAP_HOME\"\n45\tln -sfn \"$EAP_HOME_REAL\" \"$EAP_HOME\"\n46\t\n47\t# ------------------------------------------------------------------\n48\t# Step 1: Install EAP maven artifacts into local Maven cache\n49\t# ------------------------------------------------------------------\n50\techo \"=== Step 1: Installing EAP artifacts into local Maven cache ===\"\n51\t\n52\tinstall_artifact() {\n53\t    local jar=\"$1\"\n54\t    local pom=\"$2\"\n55\t    if [[ ! -f \"$jar\" ]]; then\n56\t        echo \"ERROR: Missing artifact jar: $jar\"\n57\t        exit 1\n58\t    fi\n59\t    mvn -q org.apache.maven.plugins:maven-install-plugin:3.1.1:install-file \\\n60\t        -Dfile=\"$jar\" -DpomFile=\"$pom\" 2>&1 | tail -3\n61\t}\n62\t\n63\tinstall_artifact \\\n64\t    \"$MAVEN_REPO/org/hibernate/orm/tooling/hibernate-enhance-maven-plugin/6.6.51.Final-redhat-00001/hibernate-enhance-maven-plugin-6.6.51.Final-redhat-00001.jar\" \\\n65\t    \"$MAVEN_REPO/org/hibernate/orm/tooling/hibernate-enhance-maven-plugin/6.6.51.Final-redhat-00001/hibernate-enhance-maven-plugin-6.6.51.Final-redhat-00001.pom\"\n66\t\n67\tinstall_artifact \\\n68\t    \"$MAVEN_REPO/org/hibernate/orm/hibernate-core/6.6.51.Final-redhat-00001/hibernate-core-6.6.51.Final-redhat-00001.jar\" \\\n69\t    \"$MAVEN_REPO/org/hibernate/orm/hibernate-core/6.6.51.Final-redhat-00001/hibernate-core-6.6.51.Final-redhat-00001.pom\"\n70\t\n71\tinstall_artifact \\\n72\t    \"$MAVEN_REPO/jakarta/persistence/jakarta.persistence-api/3.1.0.redhat-00002/jakarta.persistence-api-3.1.0.redhat-00002.jar\" \\\n73\t    \"$MAVEN_REPO/jakarta/persistence/jakarta.persistence-api/3.1.0.redhat-00002/jakarta.persistence-api-3.1.0.redhat-00002.pom\"\n74\t\n75\techo \"  Artifacts installed.\"\n76\t\n77\t# ------------------------------------------------------------------\n78\t# Step 2: Create test application\n79\t# ------------------------------------------------------------------\n80\techo \"=== Step 2: Creating test application ===\"\n81\t\n82\trm -rf \"$APP_DIR\"\n83\tmkdir -p \"$APP_DIR/src/main/java/com/test/entity\"\n84\tmkdir -p \"$APP_DIR/src/main/java/com/test/servlet\"\n85\tmkdir -p \"$APP_DIR/src/main/resources/META-INF\"\n86\tmkdir -p \"$APP_DIR/src/main/webapp/WEB-INF\"\n87\t\n88\t# -- pom.xml --\n89\tcat > \"$APP_DIR/pom.xml\" << 'EOF'\n90\t<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n91\t<project xmlns=\"http://maven.apache.org/POM/4.0.0\"\n92\t         xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\"\n93\t         xsi:schemaLocation=\"http://maven.apache.org/POM/4.0.0\n94\t         https://maven.apache.org/xsd/maven-4.0.0.xsd\">\n95\t    <modelVersion>4.0.0</modelVersion>\n96\t\n97\t    <groupId>com.test</groupId>\n98\t    <artifactId>enhancement-happy-path</artifactId>\n99\t    <version>1.0</version>\n100\t    <packaging>war</packaging>\n101\t\n102\t    <properties>\n103\t        <maven.compiler.source>17</maven.compiler.source>\n104\t        <maven.compiler.target>17</maven.compiler.target>\n105\t        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>\n106\t        <hibernate.version>6.6.51.Final-redhat-00001</hibernate.version>\n107\t    </properties>\n108\t\n109\t    <dependencies>\n110\t        <dependency>\n111\t            <groupId>jakarta.persistence</groupId>\n112\t            <artifactId>jakarta.persistence-api</artifactId>\n113\t            <version>3.1.0</version>\n114\t            <scope>provided</scope>\n115\t        </dependency>\n116\t        <dependency>\n117\t            <groupId>jakarta.servlet</groupId>\n118\t            <artifactId>jakarta.servlet-api</artifactId>\n119\t            <version>6.0.0</version>\n120\t            <scope>provided</scope>\n121\t        </dependency>\n122\t        <dependency>\n123\t            <groupId>jakarta.transaction</groupId>\n124\t            <artifactId>jakarta.transaction-api</artifactId>\n125\t            <version>2.0.1</version>\n126\t            <scope>provided</scope>\n127\t        </dependency>\n128\t    </dependencies>\n129\t\n130\t    <build>\n131\t        <finalName>enhancement-test</finalName>\n132\t        <plugins>\n133\t            <plugin>\n134\t                <groupId>org.hibernate.orm.tooling</groupId>\n135\t                <artifactId>hibernate-enhance-maven-plugin</artifactId>\n136\t                <version>${hibernate.version}</version>\n137\t                <executions>\n138\t                    <execution>\n139\t                        <id>enhance</id>\n140\t                        <goals>\n141\t                            <goal>enhance</goal>\n142\t                        </goals>\n143\t                        <configuration>\n144\t                            <enableLazyInitialization>true</enableLazyInitialization>\n145\t                            <enableDirtyTracking>true</enableDirtyTracking>\n146\t                        </configuration>\n147\t                    </execution>\n148\t                </executions>\n149\t            </plugin>\n150\t            <plugin>\n151\t                <groupId>org.apache.maven.plugins</groupId>\n152\t                <artifactId>maven-war-plugin</artifactId>\n153\t                <version>3.4.0</version>\n154\t                <configuration>\n155\t                    <failOnMissingWebXml>false</failOnMissingWebXml>\n156\t                </configuration>\n157\t            </plugin>\n158\t        </plugins>\n159\t    </build>\n160\t</project>\n161\tEOF\n162\t\n163\t# -- JPA Entity with lazy @Basic field --\n164\tcat > \"$APP_DIR/src/main/java/com/test/entity/Document.java\" << 'EOF'\n165\tpackage com.test.entity;\n166\t\n167\timport jakarta.persistence.Basic;\n168\timport jakarta.persistence.Column;\n169\timport jakarta.persistence.Entity;\n170\timport jakarta.persistence.FetchType;\n171\timport jakarta.persistence.GeneratedValue;\n172\timport jakarta.persistence.GenerationType;\n173\timport jakarta.persistence.Id;\n174\timport jakarta.persistence.Lob;\n175\timport jakarta.persistence.Table;\n176\t\n177\t@Entity\n178\t@Table(name = \"test_document\")\n179\tpublic class Document {\n180\t\n181\t    @Id\n182\t    @GeneratedValue(strategy = GenerationType.IDENTITY)\n183\t    private Long id;\n184\t\n185\t    @Column(nullable = false)\n186\t    private String title;\n187\t\n188\t    @Basic(fetch = FetchType.LAZY)\n189\t    @Column(length = 10000)\n190\t    private String content;\n191\t\n192\t    public Document() {}\n193\t\n194\t    public Document(String title, String content) {\n195\t        this.title = title;\n196\t        this.content = content;\n197\t    }\n198\t\n199\t    public Long getId() { return id; }\n200\t    public void setId(Long id) { this.id = id; }\n201\t    public String getTitle() { return title; }\n202\t    public void setTitle(String title) { this.title = title; }\n203\t    public String getContent() { return content; }\n204\t    public void setContent(String content) { this.content = content; }\n205\t}\n206\tEOF\n207\t\n208\t# -- Test servlet --\n209\tcat > \"$APP_DIR/src/main/java/com/test/servlet/TestServlet.java\" << 'EOF'\n210\tpackage com.test.servlet;\n211\t\n212\timport com.test.entity.Document;\n213\t\n214\timport jakarta.persistence.EntityManager;\n215\timport jakarta.persistence.PersistenceContext;\n216\timport jakarta.servlet.annotation.WebServlet;\n217\timport jakarta.servlet.http.HttpServlet;\n218\timport jakarta.servlet.http.HttpServletRequest;\n219\timport jakarta.servlet.http.HttpServletResponse;\n220\timport jakarta.transaction.Transactional;\n221\timport java.io.IOException;\n222\timport java.io.PrintWriter;\n223\t\n224\t@WebServlet(\"/test\")\n225\tpublic class TestServlet extends HttpServlet {\n226\t\n227\t    @PersistenceContext(unitName = \"test-pu\")\n228\t    private EntityManager em;\n229\t\n230\t    @Override\n231\t    protected void doGet(HttpServletRequest req, HttpServletResponse resp) throws IOException {\n232\t        resp.setContentType(\"text/plain\");\n233\t        PrintWriter out = resp.getWriter();\n234\t\n235\t        try {\n236\t            // Check if entity class is enhanced\n237\t            Class<?> docClass = Document.class;\n238\t            boolean hasInterceptor = false;\n239\t            try {\n240\t                docClass.getDeclaredField(\"$$_hibernate_attributeInterceptor\");\n241\t                hasInterceptor = true;\n242\t            } catch (NoSuchFieldException e) {\n243\t                // not enhanced\n244\t            }\n245\t\n246\t            boolean implementsInterceptable = false;\n247\t            for (Class<?> iface : docClass.getInterfaces()) {\n248\t                if (iface.getSimpleName().equals(\"PersistentAttributeInterceptable\")) {\n249\t                    implementsInterceptable = true;\n250\t                    break;\n251\t                }\n252\t            }\n253\t\n254\t            out.println(\"=== Build-Time Enhancement Check ===\");\n255\t            out.println(\"Has $$_hibernate_attributeInterceptor field: \" + hasInterceptor);\n256\t            out.println(\"Implements PersistentAttributeInterceptable: \" + implementsInterceptable);\n257\t            out.println(\"Enhancement active: \" + (hasInterceptor && implementsInterceptable));\n258\t            out.println(\"STATUS: OK\");\n259\t\n260\t        } catch (Exception e) {\n261\t            out.println(\"ERROR: \" + e.getMessage());\n262\t            e.printStackTrace(out);\n263\t        }\n264\t    }\n265\t}\n266\tEOF\n267\t\n268\t# -- persistence.xml --\n269\tcat > \"$APP_DIR/src/main/resources/META-INF/persistence.xml\" << 'EOF'\n270\t<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n271\t<persistence xmlns=\"https://jakarta.ee/xml/ns/persistence\"\n272\t             xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\"\n273\t             xsi:schemaLocation=\"https://jakarta.ee/xml/ns/persistence\n274\t             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd\"\n275\t             version=\"3.0\">\n276\t    <persistence-unit name=\"test-pu\" transaction-type=\"JTA\">\n277\t        <jta-data-source>java:jboss/datasources/ExampleDS</jta-data-source>\n278\t        <class>com.test.entity.Document</class>\n279\t        <properties>\n280\t            <property name=\"hibernate.hbm2ddl.auto\" value=\"create-drop\"/>\n281\t            <property name=\"hibernate.show_sql\" value=\"true\"/>\n282\t            <property name=\"hibernate.format_sql\" value=\"true\"/>\n283\t        </properties>\n284\t    </persistence-unit>\n285\t</persistence>\n286\tEOF\n287\t\n288\t# -- beans.xml for CDI --\n289\tcat > \"$APP_DIR/src/main/webapp/WEB-INF/beans.xml\" << 'EOF'\n290\t<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n291\t<beans xmlns=\"https://jakarta.ee/xml/ns/jakartaee\"\n292\t       xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\"\n293\t       xsi:schemaLocation=\"https://jakarta.ee/xml/ns/jakartaee\n294\t       https://jakarta.ee/xml/ns/jakartaee/beans_4_0.xsd\"\n295\t       bean-discovery-mode=\"all\" version=\"4.0\">\n296\t</beans>\n297\tEOF\n298\t\n299\techo \"  Test application created at $APP_DIR\"\n300\t\n301\t# ------------------------------------------------------------------\n302\t# Step 3: Build the application\n303\t# ------------------------------------------------------------------\n304\techo \"=== Step 3: Building test application ===\"\n305\t\n306\tcd \"$APP_DIR\"\n307\tBUILD_LOG=\"$APP_DIR/build.log\"\n308\tmvn clean package -o 2>&1 | tee \"$BUILD_LOG\"\n309\tMVN_EXIT=${PIPESTATUS[0]}\n310\t\n311\tif [[ $MVN_EXIT -ne 0 ]]; then\n312\t    echo \"\"\n313\t    echo \"WARNING: Offline build failed (exit $MVN_EXIT). Retrying with network for compile deps...\"\n314\t    mvn clean package 2>&1 | tee \"$BUILD_LOG\"\n315\t    MVN_EXIT=${PIPESTATUS[0]}\n316\tfi\n317\t\n318\tif [[ $MVN_EXIT -ne 0 ]]; then\n319\t    echo \"ERROR: Maven build failed\"\n320\t    RESULT=\"ERROR\"\n321\t    exit 1\n322\tfi\n323\t\n324\t# Check if enhancement plugin ran\n325\tif grep -qi \"enhance\" \"$BUILD_LOG\" 2>/dev/null; then\n326\t    echo \"  Enhancement plugin output found in build log.\"\n327\telse\n328\t    echo \"  WARNING: No enhancement plugin output found in build log.\"\n329\tfi\n330\t\n331\techo \"  Build succeeded.\"\n332\t\n333\t# ------------------------------------------------------------------\n334\t# Step 4: Verify bytecode enhancement in compiled classes\n335\t# ------------------------------------------------------------------\n336\techo \"=== Step 4: Verifying bytecode enhancement ===\"\n337\t\n338\tCLASSES_DIR=\"$APP_DIR/target/classes/com/test/entity\"\n339\tJAVAP_OUTPUT=$(javap -p \"$CLASSES_DIR/Document.class\" 2>&1)\n340\techo \"$JAVAP_OUTPUT\"\n341\t\n342\tENHANCED=false\n343\tif echo \"$JAVAP_OUTPUT\" | grep -q '$$_hibernate_attributeInterceptor'; then\n344\t    echo \"  FOUND: $$_hibernate_attributeInterceptor field -- entity is enhanced\"\n345\t    ENHANCED=true\n346\telse\n347\t    echo \"  NOT FOUND: $$_hibernate_attributeInterceptor field\"\n348\tfi\n349\t\n350\tif echo \"$JAVAP_OUTPUT\" | grep -q 'PersistentAttributeInterceptable'; then\n351\t    echo \"  FOUND: PersistentAttributeInterceptable interface -- entity is enhanced\"\n352\t    ENHANCED=true\n353\telse\n354\t    echo \"  NOT FOUND: PersistentAttributeInterceptable interface\"\n355\tfi\n356\t\n357\tif echo \"$JAVAP_OUTPUT\" | grep -q 'SelfDirtinessTracker'; then\n358\t    echo \"  FOUND: SelfDirtinessTracker interface -- dirty tracking enhanced\"\n359\tfi\n360\t\n361\tif [[ \"$ENHANCED\" != \"true\" ]]; then\n362\t    echo \"\"\n363\t    echo \"FAIL: Build-time enhancement did not produce enhanced bytecode.\"\n364\t    RESULT=\"FAIL\"\n365\t    exit 0\n366\tfi\n367\t\n368\techo \"  Bytecode enhancement confirmed.\"\n369\t\n370\t# ------------------------------------------------------------------\n371\t# Step 5: Start EAP\n372\t# ------------------------------------------------------------------\n373\techo \"=== Step 5: Starting EAP 8.2 ===\"\n374\t\n375\t# Use a separate base dir to avoid polluting sources.\n376\t# Must be under a path with no special characters.\n377\trm -rf \"$EAP_BASE\"\n378\tmkdir -p \"$EAP_BASE\"\n379\tcp -r \"$EAP_HOME_REAL/standalone/configuration\" \"$EAP_BASE/\"\n380\tcp -r \"$EAP_HOME_REAL/standalone/deployments\" \"$EAP_BASE/\"\n381\tmkdir -p \"$EAP_BASE/data\" \"$EAP_BASE/log\" \"$EAP_BASE/tmp\"\n382\t\n383\tSERVER_LOG=\"$EAP_BASE/log/server.log\"\n384\t\n385\t\"$EAP_HOME/bin/standalone.sh\" \\\n386\t    -Djboss.server.base.dir=\"$EAP_BASE\" \\\n387\t    -Djboss.socket.binding.port-offset=10000 \\\n388\t    > \"$APP_DIR/eap-console.log\" 2>&1 &\n389\tEAP_PID=$!\n390\t\n391\techo \"  EAP starting (PID: $EAP_PID), waiting for readiness...\"\n392\t\n393\tREADY=false\n394\tfor i in $(seq 1 90); do\n395\t    if grep -q \"WFLYSRV0025\" \"$SERVER_LOG\" 2>/dev/null; then\n396\t        READY=true\n397\t        break\n398\t    fi\n399\t    if ! kill -0 \"$EAP_PID\" 2>/dev/null; then\n400\t        echo \"ERROR: EAP process died\"\n401\t        RESULT=\"ERROR\"\n402\t        exit 1\n403\t    fi\n404\t    sleep 2\n405\tdone\n406\t\n407\tif [[ \"$READY\" != \"true\" ]]; then\n408\t    echo \"ERROR: EAP did not start within 180 seconds\"\n409\t    RESULT=\"ERROR\"\n410\t    exit 1\n411\tfi\n412\t\n413\techo \"  EAP started successfully.\"\n414\t\n415\t# Enable TRACE for Hibernate bytecode enhancement detection\n416\t\"$EAP_HOME/bin/jboss-cli.sh\" --connect \\\n417\t    --controller=localhost:19990 \\\n418\t    --command='/subsystem=logging/logger=org.hibernate:add(level=TRACE)' 2>/dev/null || true\n419\t\n420\t# ------------------------------------------------------------------\n421\t# Step 6: Deploy the WAR\n422\t# ------------------------------------------------------------------\n423\techo \"=== Step 6: Deploying test application ===\"\n424\t\n425\tWAR_FILE=\"$APP_DIR/target/enhancement-test.war\"\n426\tif [[ ! -f \"$WAR_FILE\" ]]; then\n427\t    echo \"ERROR: WAR file not found at $WAR_FILE\"\n428\t    RESULT=\"ERROR\"\n429\t    exit 1\n430\tfi\n431\t\n432\t# Copy WAR to simple path to avoid parentheses in jboss-cli deploy command\n433\tWAR_DEPLOY=\"/tmp/enhancement-test.war\"\n434\tcp \"$WAR_FILE\" \"$WAR_DEPLOY\"\n435\t\n436\t\"$EAP_HOME/bin/jboss-cli.sh\" --connect \\\n437\t    --controller=localhost:19990 \\\n438\t    --command=\"deploy $WAR_DEPLOY\" 2>&1\n439\t\n440\tsleep 5\n441\t\n442\t# Check deployment succeeded\n443\tif grep -q \"WFLYUT0021.*enhancement-test.war\" \"$SERVER_LOG\" 2>/dev/null; then\n444\t    echo \"  Deployment registered.\"\n445\telif grep -q \"enhancement-test\" \"$SERVER_LOG\" 2>/dev/null; then\n446\t    echo \"  Deployment appears in logs.\"\n447\tfi\n448\t\n449\tDEPLOY_FAILED=false\n450\tif grep -q \"WFLYCTL0080\\|WFLY.*ERROR.*enhancement-test\" \"$SERVER_LOG\" 2>/dev/null; then\n451\t    echo \"  WARNING: Deployment errors found in server log.\"\n452\t    grep \"WFLYCTL0080\\|ERROR.*enhancement-test\" \"$SERVER_LOG\" | tail -5\n453\t    DEPLOY_FAILED=true\n454\tfi\n455\t\n456\t# ------------------------------------------------------------------\n457\t# Step 7: Test the endpoint\n458\t# ------------------------------------------------------------------\n459\techo \"=== Step 7: Testing enhancement via servlet ===\"\n460\t\n461\tRESPONSE=$(curl -s -o - -w \"\\n%{http_code}\" \"http://localhost:18080/enhancement-test/test\" 2>&1)\n462\tHTTP_CODE=$(echo \"$RESPONSE\" | tail -1)\n463\tBODY=$(echo \"$RESPONSE\" | sed '$d')\n464\t\n465\techo \"HTTP Status: $HTTP_CODE\"\n466\techo \"Response body:\"\n467\techo \"$BODY\"\n468\t\n469\t# ------------------------------------------------------------------\n470\t# Step 8: Check server logs\n471\t# ------------------------------------------------------------------\n472\techo \"\"\n473\techo \"=== Step 8: Checking server logs for enhancement messages ===\"\n474\t\n475\techo \"--- Hibernate enhancement-related log entries ---\"\n476\tgrep -i \"enhance\\|HHH90009001\\|EnhancementInfo\\|bytecode\\|interceptor\" \"$SERVER_LOG\" 2>/dev/null | head -20 || echo \"  (no enhancement-related log entries found)\"\n477\t\n478\techo \"\"\n479\techo \"--- Checking for HHH90009001 (Skipping enhancement) ---\"\n480\tif grep -q \"HHH90009001\" \"$SERVER_LOG\" 2>/dev/null; then\n481\t    echo \"  FOUND: HHH90009001 -- runtime detected pre-enhanced entities\"\n482\t    grep \"HHH90009001\" \"$SERVER_LOG\" | head -5\n483\telse\n484\t    echo \"  NOT FOUND: HHH90009001 -- expected for ORM 6.6.x (this message is ORM 7.x+)\"\n485\tfi\n486\t\n487\t# ------------------------------------------------------------------\n488\t# Step 9: Determine result\n489\t# ------------------------------------------------------------------\n490\techo \"\"\n491\techo \"=== Final Assessment ===\"\n492\t\n493\tPASS=true\n494\tNOTES=\"\"\n495\t\n496\tif [[ \"$ENHANCED\" != \"true\" ]]; then\n497\t    PASS=false\n498\t    NOTES=\"${NOTES}Build-time enhancement bytecode markers not found. \"\n499\tfi\n500\t\n501\tif [[ \"$HTTP_CODE\" == \"200\" ]] && echo \"$BODY\" | grep -q \"Enhancement active: true\"; then\n502\t    echo \"  Servlet confirms enhancement is active at runtime.\"\n503\telif [[ \"$HTTP_CODE\" == \"200\" ]] && echo \"$BODY\" | grep -q \"Enhancement active: false\"; then\n504\t    echo \"  Servlet reports enhancement NOT active at runtime.\"\n505\t    PASS=false\n506\t    NOTES=\"${NOTES}Runtime check did not detect enhancement. \"\n507\telif [[ \"$HTTP_CODE\" != \"200\" ]]; then\n508\t    echo \"  Servlet endpoint returned HTTP $HTTP_CODE (may be deployment issue).\"\n509\t    NOTES=\"${NOTES}Servlet returned HTTP $HTTP_CODE. \"\n510\t    # If bytecode was enhanced but servlet failed, still note what we found\n511\t    if [[ \"$ENHANCED\" == \"true\" ]]; then\n512\t        echo \"  However, bytecode enhancement was confirmed at build time.\"\n513\t    else\n514\t        PASS=false\n515\t    fi\n516\tfi\n517\t\n518\tif [[ \"$PASS\" == \"true\" ]]; then\n519\t    RESULT=\"PASS\"\n520\telse\n521\t    RESULT=\"FAIL\"\n522\tfi\n523\t\n524\texit 0\n525\t"}]},"parent_tool_use_id":null,"session_id":"9bccde12-9349-4e4f-ad3f-28360c63e44e","uuid":"0c8fb459-9aac-4814-8c8b-c0c3d9751059","timestamp":"2026-06-19T10:06:16.237Z","tool_use_result":{"type":"text","file":{"filePath":"/home/vsalbaba/Workspace/experiment/teach-me-ralph-loops/presentation-test-run (Kopie)/output/01-happy-path.sh","content":"#!/bin/bash\n# Experiment 1: Happy Path -- Build-time Hibernate Entity Enhancement\n#\n# Verifies:\n# 1. hibernate-enhance-maven-plugin produces enhanced bytecode at build time\n# 2. Enhanced app deploys successfully to EAP 8.2\n# 3. Lazy @Basic field loading works (separate SQL for lazy field)\n# 4. Whether HHH90009001 log message appears (not expected in ORM 6.6.x)\n\nset -uo pipefail\n\nSCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"\nBASE_DIR=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"\nSOURCES=\"$BASE_DIR/sources\"\nEAP_HOME_REAL=\"$SOURCES/8.2.0.Alpha-CR39/jboss-eap-8.2\"\nMAVEN_REPO=\"$SOURCES/8.2.0.Alpha-CR39/jboss-eap-8.2.0.Alpha-maven-repository/maven-repository\"\nAPP_DIR=\"$SCRIPT_DIR/01-test-app-happy-path\"\nRESULT=\"ERROR\"\nEAP_PID=\"\"\n\n# EAP's standalone.sh uses eval which breaks on paths with parentheses/spaces.\n# Create symlinks under /tmp to work around this.\nEAP_HOME=\"/tmp/eap-test-01-home\"\nEAP_BASE=\"/tmp/eap-test-01-base\"\n\ncleanup() {\n    if [[ -n \"$EAP_PID\" ]]; then\n        \"$EAP_HOME/bin/jboss-cli.sh\" --connect \\\n            --controller=localhost:19990 command=shutdown 2>/dev/null || true\n        sleep 2\n        kill \"$EAP_PID\" 2>/dev/null || true\n        wait \"$EAP_PID\" 2>/dev/null || true\n    fi\n    rm -f \"$EAP_HOME\" /tmp/enhancement-test.war\n    rm -rf \"$EAP_BASE\"\n    echo \"\"\n    echo \"========================================\"\n    echo \"RESULT: $RESULT\"\n    echo \"========================================\"\n}\ntrap cleanup EXIT\n\n# Set up symlink for JBOSS_HOME (avoids parentheses in path)\nrm -f \"$EAP_HOME\"\nln -sfn \"$EAP_HOME_REAL\" \"$EAP_HOME\"\n\n# ------------------------------------------------------------------\n# Step 1: Install EAP maven artifacts into local Maven cache\n# ------------------------------------------------------------------\necho \"=== Step 1: Installing EAP artifacts into local Maven cache ===\"\n\ninstall_artifact() {\n    local jar=\"$1\"\n    local pom=\"$2\"\n    if [[ ! -f \"$jar\" ]]; then\n        echo \"ERROR: Missing artifact jar: $jar\"\n        exit 1\n    fi\n    mvn -q org.apache.maven.plugins:maven-install-plugin:3.1.1:install-file \\\n        -Dfile=\"$jar\" -DpomFile=\"$pom\" 2>&1 | tail -3\n}\n\ninstall_artifact \\\n    \"$MAVEN_REPO/org/hibernate/orm/tooling/hibernate-enhance-maven-plugin/6.6.51.Final-redhat-00001/hibernate-enhance-maven-plugin-6.6.51.Final-redhat-00001.jar\" \\\n    \"$MAVEN_REPO/org/hibernate/orm/tooling/hibernate-enhance-maven-plugin/6.6.51.Final-redhat-00001/hibernate-enhance-maven-plugin-6.6.51.Final-redhat-00001.pom\"\n\ninstall_artifact \\\n    \"$MAVEN_REPO/org/hibernate/orm/hibernate-core/6.6.51.Final-redhat-00001/hibernate-core-6.6.51.Final-redhat-00001.jar\" \\\n    \"$MAVEN_REPO/org/hibernate/orm/hibernate-core/6.6.51.Final-redhat-00001/hibernate-core-6.6.51.Final-redhat-00001.pom\"\n\ninstall_artifact \\\n    \"$MAVEN_REPO/jakarta/persistence/jakarta.persistence-api/3.1.0.redhat-00002/jakarta.persistence-api-3.1.0.redhat-00002.jar\" \\\n    \"$MAVEN_REPO/jakarta/persistence/jakarta.persistence-api/3.1.0.redhat-00002/jakarta.persistence-api-3.1.0.redhat-00002.pom\"\n\necho \"  Artifacts installed.\"\n\n# ------------------------------------------------------------------\n# Step 2: Create test application\n# ------------------------------------------------------------------\necho \"=== Step 2: Creating test application ===\"\n\nrm -rf \"$APP_DIR\"\nmkdir -p \"$APP_DIR/src/main/java/com/test/entity\"\nmkdir -p \"$APP_DIR/src/main/java/com/test/servlet\"\nmkdir -p \"$APP_DIR/src/main/resources/META-INF\"\nmkdir -p \"$APP_DIR/src/main/webapp/WEB-INF\"\n\n# -- pom.xml --\ncat > \"$APP_DIR/pom.xml\" << 'EOF'\n<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<project xmlns=\"http://maven.apache.org/POM/4.0.0\"\n         xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\"\n         xsi:schemaLocation=\"http://maven.apache.org/POM/4.0.0\n         https://maven.apache.org/xsd/maven-4.0.0.xsd\">\n    <modelVersion>4.0.0</modelVersion>\n\n    <groupId>com.test</groupId>\n    <artifactId>enhancement-happy-path</artifactId>\n    <version>1.0</version>\n    <packaging>war</packaging>\n\n    <properties>\n        <maven.compiler.source>17</maven.compiler.source>\n        <maven.compiler.target>17</maven.compiler.target>\n        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>\n        <hibernate.version>6.6.51.Final-redhat-00001</hibernate.version>\n    </properties>\n\n    <dependencies>\n        <dependency>\n            <groupId>jakarta.persistence</groupId>\n            <artifactId>jakarta.persistence-api</artifactId>\n            <version>3.1.0</version>\n            <scope>provided</scope>\n        </dependency>\n        <dependency>\n            <groupId>jakarta.servlet</groupId>\n            <artifactId>jakarta.servlet-api</artifactId>\n            <version>6.0.0</version>\n            <scope>provided</scope>\n        </dependency>\n        <dependency>\n            <groupId>jakarta.transaction</groupId>\n            <artifactId>jakarta.transaction-api</artifactId>\n            <version>2.0.1</version>\n            <scope>provided</scope>\n        </dependency>\n    </dependencies>\n\n    <build>\n        <finalName>enhancement-test</finalName>\n        <plugins>\n            <plugin>\n                <groupId>org.hibernate.orm.tooling</groupId>\n                <artifactId>hibernate-enhance-maven-plugin</artifactId>\n                <version>${hibernate.version}</version>\n                <executions>\n                    <execution>\n                        <id>enhance</id>\n                        <goals>\n                            <goal>enhance</goal>\n                        </goals>\n                        <configuration>\n                            <enableLazyInitialization>true</enableLazyInitialization>\n                            <enableDirtyTracking>true</enableDirtyTracking>\n                        </configuration>\n                    </execution>\n                </executions>\n            </plugin>\n            <plugin>\n                <groupId>org.apache.maven.plugins</groupId>\n                <artifactId>maven-war-plugin</artifactId>\n                <version>3.4.0</version>\n                <configuration>\n                    <failOnMissingWebXml>false</failOnMissingWebXml>\n                </configuration>\n            </plugin>\n        </plugins>\n    </build>\n</project>\nEOF\n\n# -- JPA Entity with lazy @Basic field --\ncat > \"$APP_DIR/src/main/java/com/test/entity/Document.java\" << 'EOF'\npackage com.test.entity;\n\nimport jakarta.persistence.Basic;\nimport jakarta.persistence.Column;\nimport jakarta.persistence.Entity;\nimport jakarta.persistence.FetchType;\nimport jakarta.persistence.GeneratedValue;\nimport jakarta.persistence.GenerationType;\nimport jakarta.persistence.Id;\nimport jakarta.persistence.Lob;\nimport jakarta.persistence.Table;\n\n@Entity\n@Table(name = \"test_document\")\npublic class Document {\n\n    @Id\n    @GeneratedValue(strategy = GenerationType.IDENTITY)\n    private Long id;\n\n    @Column(nullable = false)\n    private String title;\n\n    @Basic(fetch = FetchType.LAZY)\n    @Column(length = 10000)\n    private String content;\n\n    public Document() {}\n\n    public Document(String title, String content) {\n        this.title = title;\n        this.content = content;\n    }\n\n    public Long getId() { return id; }\n    public void setId(Long id) { this.id = id; }\n    public String getTitle() { return title; }\n    public void setTitle(String title) { this.title = title; }\n    public String getContent() { return content; }\n    public void setContent(String content) { this.content = content; }\n}\nEOF\n\n# -- Test servlet --\ncat > \"$APP_DIR/src/main/java/com/test/servlet/TestServlet.java\" << 'EOF'\npackage com.test.servlet;\n\nimport com.test.entity.Document;\n\nimport jakarta.persistence.EntityManager;\nimport jakarta.persistence.PersistenceContext;\nimport jakarta.servlet.annotation.WebServlet;\nimport jakarta.servlet.http.HttpServlet;\nimport jakarta.servlet.http.HttpServletRequest;\nimport jakarta.servlet.http.HttpServletResponse;\nimport jakarta.transaction.Transactional;\nimport java.io.IOException;\nimport java.io.PrintWriter;\n\n@WebServlet(\"/test\")\npublic class TestServlet extends HttpServlet {\n\n    @PersistenceContext(unitName = \"test-pu\")\n    private EntityManager em;\n\n    @Override\n    protected void doGet(HttpServletRequest req, HttpServletResponse resp) throws IOException {\n        resp.setContentType(\"text/plain\");\n        PrintWriter out = resp.getWriter();\n\n        try {\n            // Check if entity class is enhanced\n            Class<?> docClass = Document.class;\n            boolean hasInterceptor = false;\n            try {\n                docClass.getDeclaredField(\"$$_hibernate_attributeInterceptor\");\n                hasInterceptor = true;\n            } catch (NoSuchFieldException e) {\n                // not enhanced\n            }\n\n            boolean implementsInterceptable = false;\n            for (Class<?> iface : docClass.getInterfaces()) {\n                if (iface.getSimpleName().equals(\"PersistentAttributeInterceptable\")) {\n                    implementsInterceptable = true;\n                    break;\n                }\n            }\n\n            out.println(\"=== Build-Time Enhancement Check ===\");\n            out.println(\"Has $$_hibernate_attributeInterceptor field: \" + hasInterceptor);\n            out.println(\"Implements PersistentAttributeInterceptable: \" + implementsInterceptable);\n            out.println(\"Enhancement active: \" + (hasInterceptor && implementsInterceptable));\n            out.println(\"STATUS: OK\");\n\n        } catch (Exception e) {\n            out.println(\"ERROR: \" + e.getMessage());\n            e.printStackTrace(out);\n        }\n    }\n}\nEOF\n\n# -- persistence.xml --\ncat > \"$APP_DIR/src/main/resources/META-INF/persistence.xml\" << 'EOF'\n<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<persistence xmlns=\"https://jakarta.ee/xml/ns/persistence\"\n             xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\"\n             xsi:schemaLocation=\"https://jakarta.ee/xml/ns/persistence\n             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd\"\n             version=\"3.0\">\n    <persistence-unit name=\"test-pu\" transaction-type=\"JTA\">\n        <jta-data-source>java:jboss/datasources/ExampleDS</jta-data-source>\n        <class>com.test.entity.Document</class>\n        <properties>\n            <property name=\"hibernate.hbm2ddl.auto\" value=\"create-drop\"/>\n            <property name=\"hibernate.show_sql\" value=\"true\"/>\n            <property name=\"hibernate.format_sql\" value=\"true\"/>\n        </properties>\n    </persistence-unit>\n</persistence>\nEOF\n\n# -- beans.xml for CDI --\ncat > \"$APP_DIR/src/main/webapp/WEB-INF/beans.xml\" << 'EOF'\n<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<beans xmlns=\"https://jakarta.ee/xml/ns/jakartaee\"\n       xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\"\n       xsi:schemaLocation=\"https://jakarta.ee/xml/ns/jakartaee\n       https://jakarta.ee/xml/ns/jakartaee/beans_4_0.xsd\"\n       bean-discovery-mode=\"all\" version=\"4.0\">\n</beans>\nEOF\n\necho \"  Test application created at $APP_DIR\"\n\n# ------------------------------------------------------------------\n# Step 3: Build the application\n# ------------------------------------------------------------------\necho \"=== Step 3: Building test application ===\"\n\ncd \"$APP_DIR\"\nBUILD_LOG=\"$APP_DIR/build.log\"\nmvn clean package -o 2>&1 | tee \"$BUILD_LOG\"\nMVN_EXIT=${PIPESTATUS[0]}\n\nif [[ $MVN_EXIT -ne 0 ]]; then\n    echo \"\"\n    echo \"WARNING: Offline build failed (exit $MVN_EXIT). Retrying with network for compile deps...\"\n    mvn clean package 2>&1 | tee \"$BUILD_LOG\"\n    MVN_EXIT=${PIPESTATUS[0]}\nfi\n\nif [[ $MVN_EXIT -ne 0 ]]; then\n    echo \"ERROR: Maven build failed\"\n    RESULT=\"ERROR\"\n    exit 1\nfi\n\n# Check if enhancement plugin ran\nif grep -qi \"enhance\" \"$BUILD_LOG\" 2>/dev/null; then\n    echo \"  Enhancement plugin output found in build log.\"\nelse\n    echo \"  WARNING: No enhancement plugin output found in build log.\"\nfi\n\necho \"  Build succeeded.\"\n\n# ------------------------------------------------------------------\n# Step 4: Verify bytecode enhancement in compiled classes\n# ------------------------------------------------------------------\necho \"=== Step 4: Verifying bytecode enhancement ===\"\n\nCLASSES_DIR=\"$APP_DIR/target/classes/com/test/entity\"\nJAVAP_OUTPUT=$(javap -p \"$CLASSES_DIR/Document.class\" 2>&1)\necho \"$JAVAP_OUTPUT\"\n\nENHANCED=false\nif echo \"$JAVAP_OUTPUT\" | grep -q '$$_hibernate_attributeInterceptor'; then\n    echo \"  FOUND: $$_hibernate_attributeInterceptor field -- entity is enhanced\"\n    ENHANCED=true\nelse\n    echo \"  NOT FOUND: $$_hibernate_attributeInterceptor field\"\nfi\n\nif echo \"$JAVAP_OUTPUT\" | grep -q 'PersistentAttributeInterceptable'; then\n    echo \"  FOUND: PersistentAttributeInterceptable interface -- entity is enhanced\"\n    ENHANCED=true\nelse\n    echo \"  NOT FOUND: PersistentAttributeInterceptable interface\"\nfi\n\nif echo \"$JAVAP_OUTPUT\" | grep -q 'SelfDirtinessTracker'; then\n    echo \"  FOUND: SelfDirtinessTracker interface -- dirty tracking enhanced\"\nfi\n\nif [[ \"$ENHANCED\" != \"true\" ]]; then\n    echo \"\"\n    echo \"FAIL: Build-time enhancement did not produce enhanced bytecode.\"\n    RESULT=\"FAIL\"\n    exit 0\nfi\n\necho \"  Bytecode enhancement confirmed.\"\n\n# ------------------------------------------------------------------\n# Step 5: Start EAP\n# ------------------------------------------------------------------\necho \"=== Step 5: Starting EAP 8.2 ===\"\n\n# Use a separate base dir to avoid polluting sources.\n# Must be under a path with no special characters.\nrm -rf \"$EAP_BASE\"\nmkdir -p \"$EAP_BASE\"\ncp -r \"$EAP_HOME_REAL/standalone/configuration\" \"$EAP_BASE/\"\ncp -r \"$EAP_HOME_REAL/standalone/deployments\" \"$EAP_BASE/\"\nmkdir -p \"$EAP_BASE/data\" \"$EAP_BASE/log\" \"$EAP_BASE/tmp\"\n\nSERVER_LOG=\"$EAP_BASE/log/server.log\"\n\n\"$EAP_HOME/bin/standalone.sh\" \\\n    -Djboss.server.base.dir=\"$EAP_BASE\" \\\n    -Djboss.socket.binding.port-offset=10000 \\\n    > \"$APP_DIR/eap-console.log\" 2>&1 &\nEAP_PID=$!\n\necho \"  EAP starting (PID: $EAP_PID), waiting for readiness...\"\n\nREADY=false\nfor i in $(seq 1 90); do\n    if grep -q \"WFLYSRV0025\" \"$SERVER_LOG\" 2>/dev/null; then\n        READY=true\n        break\n    fi\n    if ! kill -0 \"$EAP_PID\" 2>/dev/null; then\n        echo \"ERROR: EAP process died\"\n        RESULT=\"ERROR\"\n        exit 1\n    fi\n    sleep 2\ndone\n\nif [[ \"$READY\" != \"true\" ]]; then\n    echo \"ERROR: EAP did not start within 180 seconds\"\n    RESULT=\"ERROR\"\n    exit 1\nfi\n\necho \"  EAP started successfully.\"\n\n# Enable TRACE for Hibernate bytecode enhancement detection\n\"$EAP_HOME/bin/jboss-cli.sh\" --connect \\\n    --controller=localhost:19990 \\\n    --command='/subsystem=logging/logger=org.hibernate:add(level=TRACE)' 2>/dev/null || true\n\n# ------------------------------------------------------------------\n# Step 6: Deploy the WAR\n# ------------------------------------------------------------------\necho \"=== Step 6: Deploying test application ===\"\n\nWAR_FILE=\"$APP_DIR/target/enhancement-test.war\"\nif [[ ! -f \"$WAR_FILE\" ]]; then\n    echo \"ERROR: WAR file not found at $WAR_FILE\"\n    RESULT=\"ERROR\"\n    exit 1\nfi\n\n# Copy WAR to simple path to avoid parentheses in jboss-cli deploy command\nWAR_DEPLOY=\"/tmp/enhancement-test.war\"\ncp \"$WAR_FILE\" \"$WAR_DEPLOY\"\n\n\"$EAP_HOME/bin/jboss-cli.sh\" --connect \\\n    --controller=localhost:19990 \\\n    --command=\"deploy $WAR_DEPLOY\" 2>&1\n\nsleep 5\n\n# Check deployment succeeded\nif grep -q \"WFLYUT0021.*enhancement-test.war\" \"$SERVER_LOG\" 2>/dev/null; then\n    echo \"  Deployment registered.\"\nelif grep -q \"enhancement-test\" \"$SERVER_LOG\" 2>/dev/null; then\n    echo \"  Deployment appears in logs.\"\nfi\n\nDEPLOY_FAILED=false\nif grep -q \"WFLYCTL0080\\|WFLY.*ERROR.*enhancement-test\" \"$SERVER_LOG\" 2>/dev/null; then\n    echo \"  WARNING: Deployment errors found in server log.\"\n    grep \"WFLYCTL0080\\|ERROR.*enhancement-test\" \"$SERVER_LOG\" | tail -5\n    DEPLOY_FAILED=true\nfi\n\n# ------------------------------------------------------------------\n# Step 7: Test the endpoint\n# ------------------------------------------------------------------\necho \"=== Step 7: Testing enhancement via servlet ===\"\n\nRESPONSE=$(curl -s -o - -w \"\\n%{http_code}\" \"http://localhost:18080/enhancement-test/test\" 2>&1)\nHTTP_CODE=$(echo \"$RESPONSE\" | tail -1)\nBODY=$(echo \"$RESPONSE\" | sed '$d')\n\necho \"HTTP Status: $HTTP_CODE\"\necho \"Response body:\"\necho \"$BODY\"\n\n# ------------------------------------------------------------------\n# Step 8: Check server logs\n# ------------------------------------------------------------------\necho \"\"\necho \"=== Step 8: Checking server logs for enhancement messages ===\"\n\necho \"--- Hibernate enhancement-related log entries ---\"\ngrep -i \"enhance\\|HHH90009001\\|EnhancementInfo\\|bytecode\\|interceptor\" \"$SERVER_LOG\" 2>/dev/null | head -20 || echo \"  (no enhancement-related log entries found)\"\n\necho \"\"\necho \"--- Checking for HHH90009001 (Skipping enhancement) ---\"\nif grep -q \"HHH90009001\" \"$SERVER_LOG\" 2>/dev/null; then\n    echo \"  FOUND: HHH90009001 -- runtime detected pre-enhanced entities\"\n    grep \"HHH90009001\" \"$SERVER_LOG\" | head -5\nelse\n    echo \"  NOT FOUND: HHH90009001 -- expected for ORM 6.6.x (this message is ORM 7.x+)\"\nfi\n\n# ------------------------------------------------------------------\n# Step 9: Determine result\n# ------------------------------------------------------------------\necho \"\"\necho \"=== Final Assessment ===\"\n\nPASS=true\nNOTES=\"\"\n\nif [[ \"$ENHANCED\" != \"true\" ]]; then\n    PASS=false\n    NOTES=\"${NOTES}Build-time enhancement bytecode markers not found. \"\nfi\n\nif [[ \"$HTTP_CODE\" == \"200\" ]] && echo \"$BODY\" | grep -q \"Enhancement active: true\"; then\n    echo \"  Servlet confirms enhancement is active at runtime.\"\nelif [[ \"$HTTP_CODE\" == \"200\" ]] && echo \"$BODY\" | grep -q \"Enhancement active: false\"; then\n    echo \"  Servlet reports enhancement NOT active at runtime.\"\n    PASS=false\n    NOTES=\"${NOTES}Runtime check did not detect enhancement. \"\nelif [[ \"$HTTP_CODE\" != \"200\" ]]; then\n    echo \"  Servlet endpoint returned HTTP $HTTP_CODE (may be deployment issue).\"\n    NOTES=\"${NOTES}Servlet returned HTTP $HTTP_CODE. \"\n    # If bytecode was enhanced but servlet failed, still note what we found\n    if [[ \"$ENHANCED\" == \"true\" ]]; then\n        echo \"  However, bytecode enhancement was confirmed at build time.\"\n    else\n        PASS=false\n    fi\nfi\n\nif [[ \"$PASS\" == \"true\" ]]; then\n    RESULT=\"PASS\"\nelse\n    RESULT=\"FAIL\"\nfi\n\nexit 0\n","numLines":525,"startLine":1,"totalLines":525}}}
